# Cloudflare Tunnel public URL для нашего API (subscription_server + onboarding Blueprint).
# Получается из cloudflared `--token` mode setup. Пример: https://api-aura.trycloudflare.com/api
# Если пусто — используется относительный путь /api (для same-origin при Pages Functions proxy).
VITE_API_BASE=https://api-aura.trycloudflare.com/api

# Yandex SmartCaptcha invisible site key — добавится позже когда Денис создаст капчу.
# VITE_YANDEX_CAPTCHA_SITE_KEY=ysc1_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
